{
  "uid": "caseaxis-overview",
  "title": "CaseAxis Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "caseaxis",
    "spring-boot"
  ],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate by Endpoint",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method, uri, status) (rate(http_server_requests_seconds_count{job=\"caseaxis-backend\"}[5m]))",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP P95 Latency by Endpoint",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, method, uri) (rate(http_server_requests_seconds_bucket{job=\"caseaxis-backend\"}[5m])))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "JVM Memory Used",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (area) (jvm_memory_used_bytes{job=\"caseaxis-backend\"})",
          "legendFormat": "{{area}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Hikari Connection Pool",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active{job=\"caseaxis-backend\"}",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_idle{job=\"caseaxis-backend\"}",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections_pending{job=\"caseaxis-backend\"}",
          "legendFormat": "pending"
        },
        {
          "refId": "D",
          "expr": "hikaricp_connections_max{job=\"caseaxis-backend\"}",
          "legendFormat": "max"
        }
      ]
    }
  ]
}
